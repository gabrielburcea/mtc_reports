# ============================================================================
# Educational Insights Platform - Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# ----------------------------------------------------------------------------
# OpenAI Configuration
# ----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# ----------------------------------------------------------------------------
# Databricks Configuration
# ----------------------------------------------------------------------------
DATABRICKS_HOST=adb-<workspace-id>.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>
DATABRICKS_TOKEN=dapi...

# Databricks catalog / schema (defaults used if not set)
DATABRICKS_CATALOG=edu_insights
DATABRICKS_SCHEMA=bronze

# ----------------------------------------------------------------------------
# Vector Store
# ----------------------------------------------------------------------------
VECTOR_STORE_PATH=/tmp/mtc_vector_store

# ----------------------------------------------------------------------------
# Application Settings
# ----------------------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
